# Copie para .env.development ou .env.production conforme o ambiente.
# O Vite carrega automaticamente: .env.development em dev, .env.production no build.

# === DESENVOLVIMENTO (.env.development) ===

# npm run dev / yarn dev — usa VITE_DEV_SESSION_TOKEN quando não há ?token= na URL
# VITE_API_URL=https://skinnerapi.selfsolutions.com.br
# VITE_PORTAL_RETURN_URL=https://keepweb.selfsolutions.com.br/user-selection
# URL pública do jogo (opcional; senão usa GAME_PUBLIC_URL_DEFAULT em constants.ts)
# VITE_GAME_PUBLIC_URL=https://keep-ocean.selfsolutions.com.br/
# VITE_DEV_SESSION_TOKEN=   # Token fixo para testes locais (expira; troque quando necessário)
# VITE_BYPASS_SESSION_IN_DEV=true   # Só dev: ignora API de sessão (playtest local)
# Guard de iframe: false desliga; true força também em dev. Ver README «Domínio, portal e iframe».
# VITE_ENFORCE_IFRAME_DOMAIN=false
# VITE_ALLOWED_IFRAME_ORIGINS=https://outro-portal.exemplo.com
# VITE_ALLOWED_GAME_ORIGINS=https://preview.amplifyapp.com

# === PRODUÇÃO (.env.production) ===

# npm run build — token APENAS da URL (?token=). Não definir VITE_DEV_SESSION_TOKEN.
# VITE_API_URL=https://skinnerapi.selfsolutions.com.br
# VITE_PORTAL_RETURN_URL=https://keepweb.selfsolutions.com.br/user-selection
# VITE_GAME_PUBLIC_URL=https://keep-ocean.selfsolutions.com.br/
